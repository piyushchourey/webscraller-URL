# ──────────────────────────────────────────────────────────────────────────────
# Web Scraper + AI Analyzer Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ── Gemini API Configuration ──────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ── Ollama Local Model Configuration ──────────────────────────────────────────
# Enable Ollama as the primary LLM (true/false)
USE_OLLAMA=false

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name (e.g., mistral:7b, llama2:7b, neural-chat)
OLLAMA_MODEL=mistral:7b

# ── AI Provider Selection ─────────────────────────────────────────────────────
# Primary AI provider: "gemini" or "ollama"
AI_PROVIDER=gemini

# Temperature for model responses (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.3

# Maximum output tokens for AI responses
AI_MAX_TOKENS=4096
